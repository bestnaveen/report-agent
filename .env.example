# LLM Provider: "groq" | "gemini" | "openai" | "anthropic" | "ollama"
LLM_PROVIDER=ollama

# Ollama (local) — requires Ollama running at localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_VISION_MODEL=llama3.2-vision
OLLAMA_BASE_URL=http://localhost:11434

# Groq — free tier at console.groq.com (~500 tok/s, fastest)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# Gemini — free tier at aistudio.google.com (~400 tok/s, best vision)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# OpenAI — platform.openai.com/api-keys (paid, gpt-4o-mini is cheapest)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# Anthropic Claude — console.anthropic.com (paid, best reasoning)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6

# Data processing limits
MAX_DATA_CHARS=6000
MAX_CHAT_HISTORY=10

# Multi-lingual support
MULTILINGUAL_ENABLED=true
DEFAULT_LANGUAGE=en

# RAG (Phase 2)
RAG_ENABLED=false
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# SQLite chat memory (Phase 2)
MEMORY_DB_PATH=chat_memory.db
